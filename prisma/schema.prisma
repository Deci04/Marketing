generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  COLLABORATOR
}

model Workspace {
  id          String       @id @default(cuid())
  name        String
  plan        String       @default("free")
  createdAt   DateTime     @default(now())
  memberships        Membership[]
  blocks             Block[]
  contents           Content[]
  comments           Comment[]
  measurements       Measurement[]
  benchmarks         Benchmark[]
  valueConversations ValueConversation[]
  calendarEvents     CalendarEvent[]
}

model User {
  id          String       @id @default(cuid())
  name        String?
  email       String       @unique
  image       String?
  createdAt   DateTime     @default(now())
  memberships Membership[]
  accounts    Account[]
  sessions    Session[]
  comments    Comment[]
}

model Membership {
  id          String    @id @default(cuid())
  role        Role      @default(COLLABORATOR)
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// --- Auth.js (next-auth) Prisma adapter tables ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Content domain (Modulo 2) ---

enum Channel {
  INSTAGRAM
  YOUTUBE
}

enum ContentFormat {
  REEL
  CAROUSEL
  STORY
  LONG_VIDEO
}

model Block {
  id               String    @id @default(cuid())
  workspaceId      String
  label            String
  startDate        DateTime?
  endDate          DateTime?
  lucaDeliveryAt   DateTime?
  matteoDeliveryAt DateTime?
  createdAt        DateTime  @default(now())
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contents         Content[]
  comments         Comment[]
  events           CalendarEvent[]

  @@index([workspaceId])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  workspaceId String
  blockId     String?
  date        DateTime
  title       String
  responsible String? // "LUCA" | "MATTEO" | null
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  block       Block?    @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([blockId])
}

model Content {
  id               String         @id @default(cuid())
  workspaceId      String
  blockId          String?
  title            String
  channel          Channel        @default(INSTAGRAM)
  format           ContentFormat?
  publishAt        DateTime?
  hook             String?
  notes            String?
  materialsUrl     String?
  thumbnailUrl     String?
  // performance (filled after publishing)
  views            Int?
  reach            Int?
  nonFollowerPct   Float?
  likes            Int?
  commentsCount    Int?
  saves            Int?
  shares           Int?
  followsGenerated Int?
  createdAt        DateTime       @default(now())
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  block            Block?         @relation(fields: [blockId], references: [id], onDelete: SetNull)
  comments         Comment[]
  snapshots        MetricSnapshot[]

  @@index([workspaceId])
  @@index([blockId])
}

model Comment {
  id          String    @id @default(cuid())
  workspaceId String
  contentId   String?
  blockId     String?
  authorId    String
  body        String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content     Content?  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  block       Block?    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([contentId])
  @@index([blockId])
}

// --- KPI domain ---

model Measurement {
  id          String    @id @default(cuid())
  workspaceId String
  date        DateTime
  metric      String
  value       Float
  series      String // "Luca" | "Benchmark"
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Benchmark {
  id          String    @id @default(cuid())
  workspaceId String
  metric      String
  value       Float
  rangeLabel  String?
  source      String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model ValueConversation {
  id          String    @id @default(cuid())
  workspaceId String
  date        DateTime
  who         String
  what        String
  channel     String?
  link        String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model MetricSnapshot {
  id             String   @id @default(cuid())
  contentId      String
  takenAt        DateTime @default(now())
  views          Int?
  reach          Int?
  nonFollowerPct Float?
  likes          Int?
  saves          Int?
  shares         Int?
  content        Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}
