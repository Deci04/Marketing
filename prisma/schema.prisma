generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  COLLABORATOR
}

enum ActivityType {
  DELIVERED // Luca ha consegnato il materiale
  REVIEW_READY // Matteo ha caricato il montato → da confermare
  CONFIRMED // Luca ha confermato
  COMMENT // nuovo commento (testo/audio)
  CREATED // nuovo contenuto creato
}

model Activity {
  id          String       @id @default(cuid())
  workspaceId String
  type        ActivityType
  contentId   String?
  actorId     String? // chi ha generato l'evento (per non auto-notificarsi)
  createdAt   DateTime     @default(now())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content     Content?     @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model Workspace {
  id                   String                @id @default(cuid())
  name                 String
  plan                 String                @default("free")
  createdAt            DateTime              @default(now())
  memberships          Membership[]
  blocks               Block[]
  contents             Content[]
  comments             Comment[]
  measurements         Measurement[]
  benchmarks           Benchmark[]
  valueConversations   ValueConversation[]
  calendarEvents       CalendarEvent[]
  dashboardLayouts     DashboardLayout[]
  audienceSegments     AudienceSegment[]
  zernioSnapshots      ZernioSnapshot[]
  contentClasses       ContentClass[]
  chatThreads          ChatThread[]
  chatMessages         ChatMessage[]
  activities           Activity[]
  googleCalendarConfig GoogleCalendarConfig?
  googleLinks          GoogleCalendarLink[]
  socialAccounts       SocialAccount[]
  diaryEntries         DiaryEntry[]
}

model User {
  id                  String            @id @default(cuid())
  name                String?
  email               String            @unique
  image               String?
  isAdmin             Boolean           @default(false)
  createdAt           DateTime          @default(now())
  notificationsSeenAt DateTime? // ultimo momento in cui ha aperto il feed notifiche
  telegramChatId      String?           @unique // chat Telegram collegata (filoni T/N)
  telegramLinkCode    String? // codice temporaneo di collegamento
  memberships         Membership[]
  accounts            Account[]
  sessions            Session[]
  comments            Comment[]
  dashboardLayouts    DashboardLayout[]
  chatMessages        ChatMessage[]
  pushSubscriptions   PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PushDispatch {
  id        String   @id @default(cuid())
  dedupeKey String   @unique
  sentAt    DateTime @default(now())
}

model Membership {
  id          String    @id @default(cuid())
  role        Role      @default(COLLABORATOR)
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// --- Auth.js (next-auth) Prisma adapter tables ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Content domain (Modulo 2) ---

enum Channel {
  INSTAGRAM
  YOUTUBE
  TIKTOK
}

enum ContentFormat {
  REEL
  CAROUSEL
  STORY
  LONG_VIDEO
}

model Block {
  id               String          @id @default(cuid())
  workspaceId      String
  label            String
  startDate        DateTime?
  endDate          DateTime?
  lucaDeliveryAt   DateTime?
  matteoDeliveryAt DateTime?
  createdAt        DateTime        @default(now())
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contents         Content[]
  comments         Comment[]
  events           CalendarEvent[]

  @@index([workspaceId])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  workspaceId String
  blockId     String?
  date        DateTime
  title       String
  responsible String? // "LUCA" | "MATTEO" | null
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  block       Block?    @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([blockId])
}

model Content {
  id                  String           @id @default(cuid())
  workspaceId         String
  blockId             String?
  title               String
  channel             Channel          @default(INSTAGRAM)
  format              ContentFormat?
  publishAt           DateTime?
  hook                String?
  notes               String?
  deliveredAt         DateTime? // Luca ha segnato "materiale consegnato"
  confirmedAt         DateTime? // Luca ha confermato il montato
  statusOverride      String? // stato forzato a mano (override dell'auto-derivato dalle date)
  materialsUrl        String?
  thumbnailUrl        String?
  videoProxyUrl       String? // proxy compresso di review su Blob
  masterLink          String? // link al master esterno (Drive/iCloud), percorso C
  originalDriveFileId String? // originale di publish archiviato su Drive
  // performance (filled after publishing)
  views               Int?
  reach               Int?
  nonFollowerPct      Float?
  likes               Int?
  commentsCount       Int?
  saves               Int?
  shares              Int?
  followsGenerated    Int?
  // integrazioni serata (Z ingestione / W pubblicazione)
  externalId          String? // id del post sulla piattaforma (Zernio)
  publishState        String? // null|"scheduled"|"publishing"|"published"|"failed"
  publishError        String? // messaggio ultimo errore pubblicazione
  createdAt           DateTime         @default(now())
  workspace           Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  block               Block?           @relation(fields: [blockId], references: [id], onDelete: SetNull)
  comments            Comment[]
  snapshots           MetricSnapshot[]
  classes             ContentClass[]
  materials           Material[]
  activities          Activity[]

  @@index([workspaceId])
  @@index([blockId])
  @@index([externalId])
}

model Material {
  id          String   @id @default(cuid())
  contentId   String
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  kind        String // "image" | "video"
  url         String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  driveFileId String? // originale archiviato su Google Drive (Approccio A)

  @@index([contentId])
}

model Comment {
  id             String    @id @default(cuid())
  workspaceId    String
  contentId      String?
  blockId        String?
  authorId       String
  body           String
  audioUrl       String? // commento vocale su Blob
  videoTimestamp Float? // secondo del video a cui è ancorato (null = generico)
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content        Content?  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  block          Block?    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  author         User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([contentId])
  @@index([blockId])
}

// --- KPI domain ---

model Measurement {
  id          String    @id @default(cuid())
  workspaceId String
  date        DateTime
  metric      String
  value       Float
  series      String // "Luca" | "Benchmark"
  channel     Channel? // null = Tutti / cross-canale
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Benchmark {
  id          String    @id @default(cuid())
  workspaceId String
  metric      String
  value       Float
  rangeLabel  String?
  source      String?
  channel     Channel? // null = Tutti / cross-canale
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model ValueConversation {
  id          String    @id @default(cuid())
  workspaceId String
  date        DateTime
  who         String
  what        String
  channel     String?
  link        String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model MetricSnapshot {
  id             String   @id @default(cuid())
  contentId      String
  takenAt        DateTime @default(now())
  views          Int?
  reach          Int?
  nonFollowerPct Float?
  likes          Int?
  saves          Int?
  shares         Int?
  content        Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

// ONDATA 2: snapshot Zernio "ricco" (classifica post, best-time, posting-frequency,
// content-decay, storico follower) come blob Json, upsert per (workspace, channel).
model ZernioSnapshot {
  id          String    @id @default(cuid())
  workspaceId String
  channel     Channel?
  takenAt     DateTime  @default(now())
  data        Json // ZernioSnapshotData (src/lib/zernio-snapshot.ts)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, channel])
  @@index([workspaceId])
}

// --- F1: dashboard personalizzabile + box strategici audience ---

model DashboardLayout {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  layout      Json // array react-grid-layout + elenco box nascosti
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model AudienceSegment {
  id          String    @id @default(cuid())
  workspaceId String
  channel     Channel?
  date        DateTime
  dimension   String // "age" | "gender" | "geo" | "followerType" | "activity" | "returning"
  label       String // es. "25-34", "F", "Italia", "non-follower", "lun 18-21"
  value       Float // percentuale o valore
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// --- F2: classi nominabili per raggruppare i contenuti ---

model ContentClass {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  color       String? // pastello, opzionale
  contents    Content[]
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// --- F3: chatbot agente condiviso ---

model ChatThread {
  id          String        @id @default(cuid())
  workspaceId String
  title       String?
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@index([workspaceId])
}

model ChatMessage {
  id          String     @id @default(cuid())
  threadId    String
  workspaceId String
  role        String // "user" | "assistant" | "tool"
  authorId    String? // User che ha scritto (null per l'assistente)
  content     String
  toolPayload Json? // tool call / risultato proposti o eseguiti
  status      String? // "proposed" | "confirmed" | "executed" | "rejected"
  createdAt   DateTime   @default(now())
  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author      User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([workspaceId])
}

// --- Integrazioni serata (2026-07-04) ---

model GoogleCalendarConfig {
  workspaceId       String    @id
  calendarId        String
  channelId         String?
  resourceId        String?
  watchExpiration   DateTime?
  syncToken         String?
  connectedByUserId String?
  createdAt         DateTime  @default(now())
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model GoogleCalendarLink {
  id               String    @id @default(cuid())
  workspaceId      String
  refType          String // "luca" | "matteo" | "publication" | "event"
  refId            String
  googleEventId    String
  googleCalendarId String
  etag             String?
  syncStatus       String    @default("SYNCED") // LOCAL|SYNCED|PENDING_PUSH|CONFLICT|DELETED
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, refType, refId])
  @@index([googleEventId])
}

model SocialAccount {
  id              String    @id @default(cuid())
  workspaceId     String
  platform        String // "INSTAGRAM" | "TIKTOK" | "YOUTUBE" | "LINKEDIN"
  zernioAccountId String
  handle          String?
  connectedAt     DateTime  @default(now())
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform])
  @@index([workspaceId])
}

model DiaryEntry {
  id               String    @id @default(cuid())
  workspaceId      String
  authorUserId     String?
  rawText          String?
  caption          String?
  telegramFileId   String?
  telegramFileType String? // "photo" | "video" | "document"
  aiTitle          String?
  aiDescription    String? // per le foto: descrizione via vision
  // Filone C1 — storage su Cloudflare R2 (sostituisce lo storage Telegram).
  r2Key            String? // chiave oggetto R2, es. "raw/{ws}/{id}/{file}"
  mediaUrl         String? // URL di lettura del media (via route proxy)
  mediaType        String? // "image" | "video" | "audio" | "text"
  mediaSize        Int?
  archivedAt       DateTime? // valorizzato quando spostato su Drive (C3)
  driveFileId      String? // id file su Google Drive dopo l'archiviazione (C3)
  createdAt        DateTime  @default(now())
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model DriveConfig {
  id               String   @id @default("singleton")
  rootFolderId     String?
  rawMainFolderId  String?
  rawBrollFolderId String?
  editatiFolderId  String?
  updatedAt        DateTime @updatedAt
}
